# Gemini API Key (for RAG LLM synthesis)
# Get this from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio WhatsApp Credentials
# Get these from your Twilio Console: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The Twilio Sandbox number (default is +14155238886)
TWILIO_WHATSAPP_NUMBER=+14155238886

# Google Cloud KMS / Secret Manager
GOOGLE_CLOUD_PROJECT=your-project-id
REPORT_SIGNING_SECRET_NAME=report-signing-key

# Rate Limiting (SlowAPI)
# Default limits are hardcoded in main.py but can be extended here
# REDIS_URL=redis://localhost:6379 (Optional for distributed rate limiting)

# ============================================================================
# Weather Alerts Configuration
# ============================================================================
# Open-Meteo API is FREE and requires NO API KEY
# Used for real-time weather data and crop-specific alerts
# The weather service automatically caches data to minimize API calls

# Cache duration for weather data (in seconds) - default 600 (10 minutes)
WEATHER_CACHE_DURATION=600

# Weather provider selection (default: open_meteo)
# Options: open_meteo (free, recommended)
WEATHER_API_PROVIDER=open_meteo

# For advanced/premium weather APIs (if needed in future):
# WEATHER_API_KEY=your_api_key_here  # Only needed for non-free providers

# ============================================================================
# Notification Configuration
# ============================================================================
# Enable/disable different notification channels
ENABLE_WEATHER_ALERTS=true
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=true

# ============================================================================
# Important Security Notes
# ============================================================================
# 1. NEVER commit .env file to version control (add to .gitignore)
# 2. All API keys must be kept confidential
# 3. Use environment variables instead of hardcoding secrets
# 4. Rotate secrets regularly
# 5. Use least privilege principle for service accounts
