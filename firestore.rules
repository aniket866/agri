rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────
    // ABAC (Attribute-Based Access Control) Helpers
    // ─────────────────────────────────────────────

    /**
     * Get the user's role from their Firestore profile.
     * Fail-closed: returns null if the document doesn't exist.
     */
    function getUserRole() {
      return isAuthed() 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    /**
     * Get the user's organization/farm ID from their Firestore profile.
     * Returns null if not set or user not authenticated.
     */
    function getUserOrgId() {
      return isAuthed() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('organizationId', null)
        : null;
    }

    /**
     * Get the user's organization/farm ID from custom claims in the auth token.
     * This is the preferred method as it doesn't require an extra Firestore read.
     * Falls back to Firestore profile if custom claim is not set.
     */
    function getOrgIdFromToken() {
      return isAuthed() && 'organizationId' in request.auth.token
        ? request.auth.token.organizationId
        : getUserOrgId();
    }

    /**
     * Check if the user has a specific role.
     * Supports both custom claims (preferred) and Firestore lookup (fallback).
     */
    function hasRole(role) {
      // First check custom claims in the token (no extra read)
      if (isAuthed() && 'role' in request.auth.token) {
        return request.auth.token.role == role;
      }
      // Fallback to Firestore profile
      return getUserRole() == role;
    }

    /**
     * Check if the user belongs to the same organization as the document.
     * This is the core of multi-tenant isolation.
     */
    function belongsToSameOrg(docOrgId) {
      let userOrgId = getOrgIdFromToken();
      return userOrgId != null && docOrgId != null && userOrgId == docOrgId;
    }

    /**
     * Check if the user can access a document based on organization membership.
     * Admins can access all organizations.
     */
    function canAccessOrg(docOrgId) {
      return hasRole('admin') || belongsToSameOrg(docOrgId);
    }

    /**
     * Validate that the document being created has the correct organizationId.
     * Prevents users from creating documents in other organizations.
     */
    function hasValidOrgId() {
      let userOrgId = getOrgIdFromToken();
      let docOrgId = request.resource.data.get('organizationId', null);
      
      // If user has no org, document shouldn't have one either (personal data)
      if (userOrgId == null) {
        return docOrgId == null;
      }
      
      // If user has an org, document must have the same org
      return docOrgId == userOrgId;
    }

    /**
     * Check if organizationId field is being modified.
     * Prevents users from moving documents between organizations.
     */
    function orgIdNotChanged() {
      return !('organizationId' in request.resource.data.diff(resource.data).affectedKeys())
        || resource.data.get('organizationId', null) == request.resource.data.get('organizationId', null);
    }

    // ─────────────────────────────────────────────
    // Content validation helpers
    // ─────────────────────────────────────────────

    function postContentValid() {
      return request.resource.data.content is string
        && request.resource.data.content.size() >= 20;
    }

    function commentContentValid() {
      return request.resource.data.text is string
        && request.resource.data.text.size() >= 5;
    }

    function hasServerTimestamp(field) {
      return request.resource.data[field] == request.time;
    }

    // Cooldown enforcement belongs in the backend (slowapi rate limiting).
    // These stubs keep the rules valid while the backend handles rate limits.
    function postCooldownOk() {
      return true;
    }

    function commentCooldownOk() {
      return true;
    }

    // Reputation-gain frequency cap enforced via lastReputationGain timestamp.
    function reputationCooldownOk(uid) {
      let userData = get(/databases/$(database)/documents/users/$(uid)).data;
      return !("lastReputationGain" in userData)
        || (request.time - userData.lastReputationGain) > duration.value(300, 's');
    }

    // ─────────────────────────────────────────────
    // Collection rules
    // ─────────────────────────────────────────────

    /**
     * User profiles
     * 
     * Security model:
     * - Users can read their own profile
     * - Users can read profiles in their organization
     * - Admins can read all profiles
     * - Users can only create/update their own profile
     * - organizationId cannot be changed after creation (must be set by admin)
     */
    match /users/{userId} {
      allow read: if isAuthed() && (
        request.auth.uid == userId 
        || hasRole('admin')
        || (
          exists(/databases/$(database)/documents/users/$(userId))
          && canAccessOrg(get(/databases/$(database)/documents/users/$(userId)).data.get('organizationId', null))
        )
      );
      
      allow create: if isOwner(userId)
        && hasValidOrgId();
      
      allow update: if isOwner(userId)
        && orgIdNotChanged()  // Prevent org switching
        && (
          !("reputation" in request.resource.data.diff(resource.data).affectedKeys())
          || reputationCooldownOk(userId)
        )
        && !("role" in request.resource.data.diff(resource.data).affectedKeys());  // Prevent role escalation
    }

    /**
     * Feedback
     * 
     * Security model:
     * - Only admins can read/delete feedback
     * - Authenticated users can submit feedback
     * - Feedback is automatically tagged with user's organizationId for auditing
     */
    match /feedback/{feedbackId} {
      allow read, delete: if hasRole('admin');
      
      allow create: if isAuthed()
        && hasValidOrgId()
        && request.resource.data.userId == request.auth.uid;
    }

    /**
     * Community posts
     * 
     * Security model:
     * - Users can only read posts from their organization
     * - Users can create posts in their organization
     * - Users can update their own posts (content) or any post's engagement metrics
     * - Users can delete their own posts, admins can delete any post
     * - Posts must have organizationId matching the creator's organization
     */
    match /posts/{postId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || canAccessOrg(resource.data.get('organizationId', null))
      );
      
      allow create: if isAuthed()
        && postContentValid()
        && hasServerTimestamp('createdAt')
        && request.resource.data.userId == request.auth.uid
        && hasValidOrgId()  // Must be in user's org
        && postCooldownOk();
      
      allow update: if isAuthed()
        && canAccessOrg(resource.data.get('organizationId', null))  // Must be in same org
        && orgIdNotChanged()  // Cannot move post to different org
        && (
          // Anyone in org can update engagement metrics
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentsCount']))
          // Only owner can update content
          || (isOwner(resource.data.userId) && postContentValid())
        );
      
      allow delete: if isOwner(resource.data.userId) || hasRole('admin');
    }

    /**
     * Community comments
     * 
     * Security model:
     * - Users can only read comments from their organization
     * - Users can create comments in their organization
     * - Users can update their own comments or any comment's votes
     * - Users can delete their own comments, admins can delete any comment
     */
    match /comments/{commentId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || canAccessOrg(resource.data.get('organizationId', null))
      );
      
      allow create: if isAuthed()
        && commentContentValid()
        && hasServerTimestamp('createdAt')
        && request.resource.data.userId == request.auth.uid
        && hasValidOrgId()
        && commentCooldownOk();
      
      allow update: if isAuthed()
        && canAccessOrg(resource.data.get('organizationId', null))
        && orgIdNotChanged()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'downvotes'])
          || (isOwner(resource.data.userId) && commentContentValid())
        );
      
      allow delete: if isOwner(resource.data.userId) || hasRole('admin');
    }

    /**
     * Reports (Agricultural/Bank Reports)
     * 
     * Security model:
     * - Users can only read reports from their organization
     * - Experts and admins can create reports
     * - Reports must be tagged with organizationId
     * - Only admins can modify/delete reports
     */
    match /reports/{reportId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || hasRole('expert')
        || canAccessOrg(resource.data.get('organizationId', null))
      );
      
      allow create: if (hasRole('expert') || hasRole('admin'))
        && hasValidOrgId();
      
      allow update, delete: if hasRole('admin');
    }

    /**
     * Marketplace
     * 
     * Security model:
     * - Public read access (marketplace is public)
     * - Vendors can create listings in their organization
     * - Vendors can only update/delete their own listings
     * - Admins can modify any listing
     * - Listings are tagged with organizationId for filtering
     */
    match /marketplace/{itemId} {
      allow read: if true;  // Public marketplace
      
      allow create: if (hasRole('vendor') || hasRole('admin'))
        && hasValidOrgId()
        && request.resource.data.get('vendorId', null) == request.auth.uid;
      
      allow update: if isAuthed()
        && orgIdNotChanged()
        && (
          hasRole('admin')
          || (hasRole('vendor') && resource.data.get('vendorId', null) == request.auth.uid)
        );
      
      allow delete: if hasRole('admin')
        || (hasRole('vendor') && resource.data.get('vendorId', null) == request.auth.uid);
    }

    /**
     * Farming Activities
     * 
     * Security model:
     * - Users can only read/write their own activities
     * - Activities are scoped to user's organization
     * - Admins can read all activities
     */
    match /activities/{activityId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || (
          resource.data.userId == request.auth.uid
          && canAccessOrg(resource.data.get('organizationId', null))
        )
      );
      
      allow create: if isAuthed()
        && request.resource.data.userId == request.auth.uid
        && hasValidOrgId();
      
      allow update, delete: if isAuthed()
        && resource.data.userId == request.auth.uid
        && orgIdNotChanged();
    }

    /**
     * Yield History
     * 
     * Security model:
     * - Users can only read/write their own yield records
     * - Records are scoped to user's organization
     * - Admins and experts can read all records in their org
     */
    match /yield_history/{recordId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || (hasRole('expert') && canAccessOrg(resource.data.get('organizationId', null)))
        || (
          resource.data.get('userId', null) == request.auth.uid
          && canAccessOrg(resource.data.get('organizationId', null))
        )
      );
      
      allow create: if isAuthed()
        && request.resource.data.get('userId', null) == request.auth.uid
        && hasValidOrgId();
      
      allow update, delete: if isAuthed()
        && resource.data.get('userId', null) == request.auth.uid
        && orgIdNotChanged();
    }

    /**
     * Public Keys (for E2E encryption)
     * 
     * Security model:
     * - Users can read public keys in their organization
     * - Users can only write their own public key
     * - Public keys are scoped to organization for privacy
     */
    match /public_keys/{userId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || request.auth.uid == userId
        || (
          exists(/databases/$(database)/documents/public_keys/$(userId))
          && canAccessOrg(get(/databases/$(database)/documents/public_keys/$(userId)).data.get('organizationId', null))
        )
      );
      
      allow write: if isOwner(userId)
        && hasValidOrgId();
    }

    /**
     * Chat Messages
     * 
     * Security model:
     * - Users can only read messages where they are sender or recipient
     * - Messages must be between users in the same organization
     * - Admins can read all messages in their organization
     */
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || resource.data.senderId == request.auth.uid
        || resource.data.recipientId == request.auth.uid
      );
      
      allow create: if isAuthed()
        && request.resource.data.senderId == request.auth.uid
        && hasValidOrgId()
        // Verify recipient is in same organization
        && (
          hasRole('admin')
          || belongsToSameOrg(
            get(/databases/$(database)/documents/users/$(request.resource.data.recipientId)).data.get('organizationId', null)
          )
        );
      
      allow update, delete: if isAuthed()
        && resource.data.senderId == request.auth.uid;
    }

    /**
     * Organizations/Farms
     * 
     * Security model:
     * - Users can read their own organization details
     * - Only admins can create/update/delete organizations
     * - Organization members can read basic org info
     */
    match /organizations/{orgId} {
      allow read: if isAuthed() && (
        hasRole('admin')
        || getOrgIdFromToken() == orgId
      );
      
      allow create, update, delete: if hasRole('admin');
    }

    /**
     * Default deny rule
     * 
     * Any collection not explicitly listed above is denied by default.
     * This fail-closed approach prevents accidental data exposure.
     */
  }
}
